  "webedit-430": {
    "type": "text",
    "tagName": "p",
    "value": "Kingsman garments are cut to a traditional British standard. We recommend measuring over a \n      well-fitted shirt for the most accurate sizing. Our Master Fitters are available for a complimentary \n      video consultation Monday–Friday, 9am–5pm GMT."
  },
  "webedit-439": {
    "type": "text",
    "tagName": "p",
    "value": "All measurements are body measurements. Add 1–1.5\" for ease of movement."
  },
  "webedit-441": {
    "type": "text",
    "tagName": "p",
    "value": "Every Kingsman bespoke commission begins with a consultation with one of our twelve Master Cutters, \n      each trained for a minimum of seven years on Savile Row. The process is meticulous, unhurried, and \n      entirely focused on you."
  },
